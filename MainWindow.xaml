<Window x:Class="WPF_Desafio.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WPF_Desafio"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800" Loaded="Window_Loaded">
    <Window.Resources>
        <CollectionViewSource x:Key="ticketsViewSource"/>
        <CollectionViewSource x:Key="commentsViewSource" 
                              Source="{Binding Comments, Source={StaticResource ticketsViewSource}}"/>
    </Window.Resources>
    <Grid>
        <Label Content="Tickets:" FontWeight="Bold" Margin="13,0,0,0" VerticalAlignment="Top" />
        <DataGrid x:Name="ticketsDataGrid" AutoGenerateColumns="False" 
          EnableRowVirtualization="True" 
          ItemsSource="{Binding Source={StaticResource ticketsViewSource}}" 
          Margin="13,25,43,249" RowDetailsVisibilityMode="VisibleWhenSelected">
            <DataGrid.Columns>
                <DataGridTextColumn Binding="{Binding Title}" Header="Título" Width="*"/>
                <DataGridTextColumn Binding="{Binding Description}" Header="Descripción" Width="2*"/>
                <DataGridTextColumn Binding="{Binding State}" Header="Estado" Width="Auto"/>
                <DataGridTextColumn Binding="{Binding Author.Name}" Header="Autor" Width="Auto"/>
            </DataGrid.Columns>
        </DataGrid>

        <Label Content="Comentarios:" FontWeight="Bold" Margin="13,190,0,0" VerticalAlignment="Top" />
        <DataGrid x:Name="commentsDataGrid" AutoGenerateColumns="False" 
          EnableRowVirtualization="True" 
          ItemsSource="{Binding Source={StaticResource commentsViewSource}}" 
          Margin="13,215,43,98" RowDetailsVisibilityMode="VisibleWhenSelected" 
          RenderTransformOrigin="0.488,0.251">
            <DataGrid.Columns>
                <DataGridTextColumn Binding="{Binding Content}" Header="Contenido" Width="*"/>
                <DataGridTextColumn Binding="{Binding Author.Name}" Header="Autor" Width="Auto"/>
                <DataGridTextColumn Binding="{Binding CreatedAt, StringFormat=\{0:g\}}" Header="Creada el" Width="Auto" IsReadOnly="True"/>
            </DataGrid.Columns>
        </DataGrid>

        <Button Content="Save" HorizontalAlignment="Center" Margin="0,380,0,0" 
        Click="Button_Click" Height="30" Width="123" VerticalAlignment="Top"/>
    </Grid>
</Window>
